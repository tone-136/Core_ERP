<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree (List) View -->
    <record id="view_unit_part_tree" model="ir.ui.view">
        <field name="name">unit.part.tree</field>
        <field name="model">unit.part</field>
        <field name="arch" type="xml">
            <tree string="Unit or Part">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_unit_part_form" model="ir.ui.view">
        <field name="name">unit.part.form</field>
        <field name="model">unit.part</field>
        <field name="arch" type="xml">
            <form string="Unit or Part">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_unit_part" model="ir.actions.act_window">
        <field name="name">Unit or Part</field>
        <field name="res_model">unit.part</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Unit or Part
            </p>
        </field>
    </record>

    <!-- Level 2: Unit or Part -->
    <menuitem
        id="menu_unit_part"
        name="Unit or Part"
        parent="menu_master_data_configuration"
        action="action_unit_part"
        sequence="40"/>

</odoo>
